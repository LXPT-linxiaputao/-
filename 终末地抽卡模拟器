class Sprite {
  PImage img;
  float x, y, w, h;
  Sprite(String url, float x, float y, float w, float h) {
    this.img = loadImage(url);
    this.x = x;
    this.y = y;
    this.w = w;
    this.h = h;
  }
  void draw() {
    if (img != null) {
      imageMode(CENTER);
      image(img, x, y, w, h);
      imageMode(CORNER);
    }
  }
  void drawFullScreen() {
    if (img != null) {
      imageMode(CENTER);
      image(img, width/2, height/2, w, h);
      imageMode(CORNER);
    }
  }
}

class Operator {
  String name;
