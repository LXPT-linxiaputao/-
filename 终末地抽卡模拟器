void mousePressed() {
if (showQueue.size() > 0) {
showQueue.remove(0);
return;
}
if (isWindowOpen) {
if (mouseX >= 420 && mouseX <= 446 && mouseY >= 40 && mouseY <= 66) {
isWindowOpen = false;
}
return;
}
if (isStoreOpen) {
if (mouseX >= width - 40 && mouseX <= width - 15 && mouseY >= 10 && mouseY <= 35) {
isStoreOpen = false;
return;
}
int[] addValues = new int[]{12, 21, 34, 57, 92, 194};
for (int i = 0; i < 6; i++) {
int cardX = 25 + i * 78;
if (mouseX >= cardX + 5 && mouseX <= cardX + 73 && mouseY >= 280 && mouseY <= 310) {
yanZhiYuanShi += addValues[i];
}
}
return;
}
if (dialogType > 0) {
if (mouseX >= 130 && mouseX <= 240 && mouseY >= 252 && mouseY <= 276) {
dialogType = 0;
}
else if (mouseX >= 260 && mouseX <= 370 && mouseY >= 252 && mouseY <= 276) {
if (dialogType == 1) {
qianJingYu -= 5000; dialogType = 0; currentResult.clear();
for (int i = 0; i < 10; i++) executeSingleGacha();
}
else if (dialogType == 2) {
qianJingYu -= 500; dialogType = 0; currentResult.clear();
executeSingleGacha();
}
else if (dialogType == 3) {
dialogType = 0; isStoreOpen = true;
}
else if (dialogType == 4) {
boolean isSingle = (dialogType == 2);
int missing = isSingle ? 500 - qianJingYu : 5000 - qianJingYu;
if (missing < 0) missing = 0;
int needYuanShi = ceil((float)missing / 75);
yanZhiYuanShi -= needYuanShi;
qianJingYu += needYuanShi * 75;
dialogType = 0;
if (!isSingle) {
qianJingYu -= 5000;
currentResult.clear();
for(int i = 0; i < 10; i++) executeSingleGacha();
} else {
qianJingYu -= 500;
currentResult.clear();
executeSingleGacha();
}
}
}
return;
}
if (mouseX >= 250 && mouseX <= 360 && mouseY >= height - 50 && mouseY <= height - 14) {
if (qianJingYu >= 500) dialogType = 2;
else {
int missing = 500 - qianJingYu; int needYuanShi = ceil((float)missing / 75);
if (yanZhiYuanShi >= needYuanShi) dialogType = 4; else dialogType = 3;
}
}
else if (mouseX >= 375 && mouseX <= 485 && mouseY >= height - 50 && mouseY <= height - 14) {
if (qianJingYu >= 5000) dialogType = 1;
else {
int missing = 5000 - qianJingYu; int needYuanShi = ceil((float)missing / 75);
if (yanZhiYuanShi >= needYuanShi) dialogType = 4; else dialogType = 3;
}
}
}

